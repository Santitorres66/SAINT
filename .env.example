# ------------------------------------------------------------------
# Variables de entorno de SAINT
# Copiá este archivo como ".env.local" y completá con tus valores reales.
# El .env.local NO se sube a git (está en .gitignore).
# ------------------------------------------------------------------

# URL de tu proyecto Supabase (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública / publishable (Settings → API → Project API keys → anon/public)
# Es segura de exponer en el navegador: quien protege los datos es RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------------
# Mercado Pago + órdenes automáticas (fase de pagos)
# ------------------------------------------------------------------

# URL pública del sitio (para las vueltas de pago y el webhook).
# En local: http://localhost:3000 · En Vercel: https://tu-dominio.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Access Token de Mercado Pago (Tus integraciones → Credenciales).
# SECRETO — solo servidor. Usá el de PRUEBA (TEST) para probar sin plata real.
MP_ACCESS_TOKEN=APP_USR-o-TEST-xxxxxxxxxxxxxxxx

# (Opcional) Clave secreta del webhook de Mercado Pago para validar la firma.
MP_WEBHOOK_SECRET=

# Clave SECRETA (service_role) de Supabase (Settings → API → service_role).
# ⚠️ MUY PODEROSA: solo servidor, NUNCA en el navegador ni en git.
# Se usa para guardar órdenes y descontar stock desde el webhook.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...tu_clave_service_role
